# Copy this to .env and adjust values before running docker-compose

# Required: path to your parquet files on the host
PARQUET_DATA_PATH=./parquet-data

# Change ALL of these in production!
JWT_SECRET=telemetry-search-dev-secret-change-in-production
ADMIN_PASSWORD=admin123
WRITER_PASSWORD=writer123
READER_PASSWORD=reader123

# Origin allowed for CORS (default is fine for local dev)
ALLOWED_ORIGIN=http://localhost:3000

# For local frontend dev only (npm run dev)
# VITE_API_URL=http://localhost:3000
